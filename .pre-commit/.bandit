# Bandit configuration for security analysis
# Project: EyesDcar
# Date: 22/04/2026

# Excluded tests (Bandit identifiers)
skips:
  - B101  # assert_used - Legitimate in unit tests
  - B601  # paramiko_calls - If usage is secure
  - B701  # flake8-bugbear - personal opinions

# Excluded directories
exclude_dirs:
  - /tests/
  - /docs/
  - /.venv/
  - /venv/
  - /.github/scripts/
  - /__pycache__/
  - /build/
  - /dist/

# Minimum severity level to alert
# Options: LOW, MEDIUM, HIGH
severity: MEDIUM

# Minimum confidence level
# Options: LOW, MEDIUM, HIGH
confidence: MEDIUM

# Specific tests to run (empty = all)
tests: []

# Output format
# Options: csv, json, txt, html, screen, yaml
format: screen
